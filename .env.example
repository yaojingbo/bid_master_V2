# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bidmaster

# LLM Providers (API Keys)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DASHSCOPE_API_KEY=sk-your-dashscope-key
ZHIPU_API_KEY=your-zhipu-key
MINIMAX_API_KEY=your-minimax-key
OPENAI_API_KEY=sk-your-openai-key
CLAUDE_API_KEY=your-claude-key

# Ollama (optional, for local)
OLLAMA_BASE_URL=http://localhost:11434

# Encryption
FERNET_KEY=your-32-byte-base64-encoded-key

# Backend URL used by Next.js API Routes and rewrites.
# 生产环境必须在 Vercel 配置为当前 Railway 后端公网地址，避免硬编码旧域名导致 404。
BACKEND_URL=http://localhost:8000

# Frontend business API direct connection.
# 生产方案 B：认证继续走同源 /api/auth/*，大文件上传、下载、OCR/SSE 等重接口可直连 Railway 后端。
NEXT_PUBLIC_BACKEND_API_URL=https://bidmasterv2-production.up.railway.app

# Frontend — 不建议生产环境设置此变量；它会让所有 API 包括认证相关调用倾向外部地址。
# 仅在本地开发需要前端全部直连后端时设置：NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend CORS / OCR
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://bid-master-v2.vercel.app
PADDLEOCR_HOME=/data/paddleocr
OCR_SAVE_EVIDENCE=false
OCR_EVIDENCE_DIR=/data/ocr-evidence
